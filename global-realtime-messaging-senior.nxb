      icon: lucide:radio,
      style: edge,
      x: 800,
      y: 48,
      width: 224,
      height: 128
    ]

    node api_gateway "HTTPS API Gateway" [
      subtitle: "Uploads, History and Device APIs",
      kind: gateway,
      icon: lucide:waypoints,
      style: edge,
      x: 400,
      y: 320,
      width: 224,
      height: 128
    ]

    node edge_rate_limiter "Distributed Rate Limiter" [
      subtitle: "Per User, Device and IP Quotas",

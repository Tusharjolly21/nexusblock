    route: orthogonal
  ]

  edge e10 auth_service -> device_registry [
    label: "Verify trusted device",
    kind: data,
    route: orthogonal
  ]

  edge e11 websocket_gateway -> edge_rate_limiter [
    label: "Enforce message and connection quotas",
    kind: security,
    route: orthogonal
  ]

  edge e12 edge_rate_limiter -> chat_ingress [
    label: "Forward accepted message envelope",

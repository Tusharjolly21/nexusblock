    route: orthogonal
  ]

  edge e40 receipt_service -> message_store [
    label: "Update delivery state",
    kind: data,
    route: orthogonal
  ]

  edge e41 receipt_stream -> delivery_router [
    label: "Route receipt to sender sessions",

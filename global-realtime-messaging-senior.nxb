    route: orthogonal
  ]

  edge e45 history_service -> recipient_device [
    label: "Return missed encrypted messages",
    kind: data,
    route: orthogonal,
    animate: true
  ]

  edge e46 sender_device -> api_gateway [
    label: "Request signed media upload session",
    kind: sync,
    route: orthogonal
  ]

  edge e47 api_gateway -> media_upload_service [
    label: "Create multipart upload authorization",
    kind: sync,
    route: orthogonal
  ]

  edge e48 media_upload_service -> sender_device [
    label: "Return signed upload URLs",
    kind: sync,
    route: orthogonal
  ]

  edge e49 sender_device -> encrypted_object_storage [
    label: "Upload client-encrypted media directly",

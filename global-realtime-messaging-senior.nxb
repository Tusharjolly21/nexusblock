      x: 576,
      y: 624,
      width: 224,
      height: 128
    ]

    node group_fanout_worker "Large Group Fanout Workers" [
      subtitle: "Asynchronous Recipient Expansion",
      kind: compute,
      icon: lucide:git-fork,
      style: compute,
      x: 928,
      y: 624,
      width: 224,
      height: 128
    ]
  }

  group ordering_storage "Ordering, Durable Storage and Event Backbone" [
    x: 2350,
    y: 100,
    width: 1550,
    height: 1000
  ] {
    node message_stream "Partitioned Message Stream" [

    route: orthogonal
  ]

  edge e18 chat_ingress -> idempotency_service [
    label: "Validate client message ID",
    kind: sync,
    route: orthogonal
  ]

  edge e19 idempotency_service -> dedup_store [
    label: "Check and reserve deduplication key",
    kind: data,
    route: orthogonal
  ]

  edge e20 chat_ingress -> conversation_service [
    label: "Verify membership and fanout policy",
    kind: sync,
    route: orthogonal
  ]

  edge e21 conversation_service -> conversation_store [
    label: "Read participants, roles and sequence state",
    kind: data,
    route: orthogonal
  ]

  edge e22 chat_ingress -> message_store [
    label: "Persist encrypted message before acknowledgement",
    kind: data,
    route: orthogonal,
    animate: true
  ]

  edge e23 message_store -> chat_ingress [
    label: "Durable write acknowledgement",
    kind: sync,
    route: orthogonal
  ]

  edge e24 chat_ingress -> sender_device [
    label: "Return server message ID and accepted status",
    kind: sync,
    route: orthogonal
  ]

  edge e25 chat_ingress -> message_stream [
    label: "Publish ordered event by conversation ID",
    kind: event,
    route: orthogonal,
    animate: true
  ]

  edge e26 message_stream -> group_fanout_worker [
    label: "Expand recipients for large groups",
    kind: stream,
    route: orthogonal
  ]

  edge e27 message_stream -> delivery_router [
    label: "Consume ordered message events",
    kind: stream,
    route: orthogonal,
    animate: true
  ]

  edge e28 group_fanout_worker -> delivery_router [
    label: "Submit recipient delivery tasks",
    kind: async,
    route: orthogonal
  ]

  edge e29 delivery_router -> session_registry [
    label: "Resolve active recipient sessions",
    kind: data,
    route: orthogonal
  ]

  edge e30 delivery_router -> websocket_gateway [
    label: "Route message to owning gateway",
    kind: stream,
    route: orthogonal,
    animate: true
  ]

  edge e31 websocket_gateway -> recipient_device [
    label: "Deliver encrypted message",
    kind: stream,
    route: orthogonal,
    animate: true
  ]

  edge e32 delivery_router -> offline_delivery [
    label: "No active recipient session",
    kind: failure,
    route: orthogonal
  ]

  edge e33 offline_delivery -> pending_store [
    label: "Record pending per-device delivery cursor",
    kind: data,
    route: orthogonal
  ]

  edge e34 offline_delivery -> push_service [
    label: "Request minimal wake-up notification",
    kind: event,
    route: orthogonal
  ]

  edge e35 push_service -> mobile_push_providers [
    label: "Send platform push request",
    kind: async,
    route: orthogonal
  ]

  edge e36 mobile_push_providers -> recipient_device [

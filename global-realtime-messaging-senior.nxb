    route: orthogonal
  ]

  edge e13 websocket_gateway -> session_registry [
    label: "Register user, device and gateway session",
    kind: data,
    route: orthogonal
  ]

  edge e14 websocket_gateway -> presence_service [
    label: "Connection and heartbeat events",
    kind: event,
    route: orthogonal
  ]

  edge e15 sender_device -> key_directory [
    label: "Fetch recipient identity keys and signed prekeys",

diagram global_realtime_messaging "Global Real-Time Messaging Platform" {
  type: architecture
  direction: LR
  layout: manual

  canvas: {
    width: 7000,
    height: 2700,
    background: "#151515",
    grid: 24
  }

  catalog: {
    category: "Messaging",
    difficulty: "Advanced",
    provider: "Cloud Neutral",
    tags: ["real-time-chat", "websocket", "kafka", "cassandra", "presence", "multi-region"],
    animated: true,
    editable: true
  }

  styles: {
    user:     { fill: "#E8F0FE", stroke: "#4F46E5", text: "#111827" },
    edge:     { fill: "#FFF7ED", stroke: "#EA580C", text: "#111827" },
    security: { fill: "#FFF1F2", stroke: "#E11D48", text: "#111827" },
    compute:  { fill: "#ECFDF5", stroke: "#059669", text: "#111827" },
    data:     { fill: "#F5F3FF", stroke: "#7C3AED", text: "#111827" },
    stream:   { fill: "#ECFEFF", stroke: "#0891B2", text: "#111827" },
    media:    { fill: "#FEF2F2", stroke: "#DC2626", text: "#111827" },
    ops:      { fill: "#F3F4F6", stroke: "#4B5563", text: "#111827" }
  }

  group clients "Client Applications" [
    x: -1750,
    y: -450,
    width: 320,
    height: 704
  ] {
    node sender_device "Sender Mobile Device" [
      subtitle: "End-to-End Encryption Client",
      kind: client,
      icon: lucide:smartphone,
      style: user,
      x: 48,
      y: 48,
      width: 224,
      height: 128
    ]

    node recipient_device "Recipient Mobile Device" [
      subtitle: "Online or Offline Recipient",
      kind: client,
      icon: lucide:smartphone,
      style: user,
      x: 48,
      y: 240,
      width: 224,
      height: 128
    ]

    node web_client "Web and Desktop Client" [
      subtitle: "Linked Device Session",
      kind: client,
      icon: lucide:monitor,
      style: user,
      x: 48,
      y: 432,
      width: 224,
      height: 128
    ]
  }

  group edge_connection "Global Edge and Connection Layer" [
    x: -850,
    y: -450,

    route: orthogonal,
    animate: true
  ]

  edge e50 encrypted_object_storage -> media_processing [
    label: "Validate format and derive safe metadata",
    kind: event,
    route: orthogonal
  ]

  edge e51 encrypted_object_storage -> media_cdn [
    label: "Serve encrypted media origin",
    kind: data,
    route: orthogonal
  ]

  edge e52 media_cdn -> recipient_device [
    label: "Download encrypted media with signed URL",
    kind: stream,
    route: orthogonal,
    animate: true
  ]

  edge e53 websocket_gateway -> home_region_directory [
    label: "Resolve user and conversation home region",
    kind: data,
    route: orthogonal
  ]

  edge e54 message_store -> change_data_capture [
    label: "Emit committed message changes",
    kind: stream,
    route: orthogonal
  ]

  edge e55 change_data_capture -> replication_pipeline [
    label: "Replicate durable changes with replay",
    kind: stream,
    route: orthogonal
  ]

  edge e56 replication_pipeline -> secondary_message_store [
    label: "Write warm recovery copy",
    kind: data,
    route: orthogonal
  ]

  edge e57 failover_controller -> global_load_balancer [
    label: "Shift traffic after health and fencing checks",
    kind: reliability,
    route: orthogonal,
    line: dashed
  ]

  edge e58 failover_controller -> conflict_guard [
    label: "Issue new writer epoch",
    kind: security,
    route: orthogonal
  ]

  edge e59 conflict_guard -> secondary_message_store [
    label: "Permit single-writer recovery mode",
    kind: security,
    route: orthogonal
  ]

  edge e60 secondary_message_store -> replay_coordinator [
    label: "Provide replicated messages and cursors",
    kind: data,
    route: orthogonal
  ]

  edge e61 replay_coordinator -> delivery_router [
    label: "Resume pending delivery after failover",
    kind: async,
    route: orthogonal
  ]

  edge e62 retention_worker -> message_store [
    label: "Apply TTL, deletion and legal hold policy",
    kind: governance,
    route: orthogonal,
    line: dashed
  ]

  edge e63 retention_worker -> encrypted_object_storage [
    label: "Delete expired or user-removed media",
    kind: governance,
    route: orthogonal,
    line: dashed
  ]

  edge e64 search_index -> history_service [
    label: "Resolve server-visible metadata filters",
    kind: data,
    route: orthogonal
  ]

  edge e65 websocket_gateway -> telemetry_collector [
    label: "Connection, latency and error telemetry",
    kind: observability,
    route: orthogonal,
    line: dashed
  ]

  edge e66 chat_ingress -> telemetry_collector [
    label: "Message acceptance and persistence traces",
    kind: observability,
    route: orthogonal,
    line: dashed
  ]

  edge e67 delivery_router -> telemetry_collector [
    label: "Delivery latency and fanout telemetry",
    kind: observability,
    route: orthogonal,
    line: dashed
  ]

  edge e68 message_stream -> telemetry_collector [
    label: "Partition lag and hot-key metrics",
    kind: observability,
    route: orthogonal,
    line: dashed
  ]

  edge e69 telemetry_collector -> metrics_store [
    label: "Export metrics and exemplars",
    kind: observability,
    route: orthogonal
  ]

  edge e70 metrics_store -> dashboards [
    label: "Query service and SLO dashboards",
    kind: observability,
    route: orthogonal
  ]

  edge e71 metrics_store -> alerting [
    label: "Evaluate burn-rate and saturation alerts",
    kind: notification,
    route: orthogonal
  ]

  edge e72 auth_service -> audit_archive [
    label: "Record security and device trust changes",
    kind: governance,
    route: orthogonal,
    line: dashed
  ]

  edge e73 key_directory -> audit_archive [
    label: "Record key publication and rotation events",
    kind: governance,
    route: orthogonal,
    line: dashed
  ]

  edge e74 capacity_controller -> websocket_gateway [
    label: "Scale gateway capacity by active connections",
    kind: reliability,
    route: orthogonal,
    line: dashed
  ]

  edge e75 capacity_controller -> message_stream [
    label: "Rebalance partitions and hot conversations",
    kind: reliability,
    route: orthogonal,
    line: dashed
  ]

  animation realtime_message_delivery {
    step 1 [
      activate: [sender_device, global_dns, global_load_balancer, websocket_gateway],
      edges: [e01, e04, e05],
      narration: "The sender connects to the nearest healthy regional WebSocket gateway over TLS."
    ]

    step 2 [
      activate: [websocket_gateway, auth_service, device_registry, session_registry],
      edges: [e07, e10, e13],
      narration: "The gateway validates the session, verifies the device and registers the active connection."
    ]

    step 3 [
      activate: [sender_device, key_directory, websocket_gateway, edge_rate_limiter, chat_ingress],
      edges: [e15, e16, e11, e12],
      effect: stream-packet,
      narration: "The sender encrypts the message for recipient devices and submits the encrypted envelope."
    ]

    step 4 [
      activate: [chat_ingress, idempotency_service, conversation_service, message_store],
      edges: [e18, e20, e22, e23],
      narration: "The ingress path verifies idempotency and membership, then durably stores the encrypted message before acknowledging it."
    ]

    step 5 [
      activate: [chat_ingress, message_stream, delivery_router, session_registry],
      edges: [e25, e27, e29],
      effect: data-flow,
      narration: "The message is published to a conversation-partitioned stream, preserving per-conversation ordering."
    ]

    step 6 [
      activate: [delivery_router, websocket_gateway, recipient_device],
      edges: [e30, e31],
      effect: stream-packet,
      narration: "The delivery router resolves the recipient session and pushes the encrypted message through the owning gateway."
    ]

    step 7 [
      activate: [recipient_device, websocket_gateway, receipt_service, receipt_stream, sender_device],
      edges: [e37, e38, e39, e41],
      narration: "Delivered and read receipts flow back through a separate receipt stream to the sender's active sessions."
    ]
  }

  animation offline_delivery_and_reconnect {
    step 1 [
      activate: [delivery_router, session_registry, offline_delivery],
      edges: [e29, e32],
      narration: "The recipient has no active session, so delivery is handed to the offline coordinator."
    ]

    step 2 [
      activate: [offline_delivery, pending_store, push_service, mobile_push_providers],
      edges: [e33, e34, e35],
      narration: "The platform records a pending delivery cursor and sends a minimal push notification without message plaintext."
    ]

    step 3 [
      activate: [mobile_push_providers, recipient_device, websocket_gateway],
      edges: [e36, e37],
      effect: notification-pulse,
      narration: "The device wakes, reconnects and re-establishes an authenticated session."
    ]

    step 4 [
      activate: [api_gateway, history_service, pending_store, message_store, recipient_device],
      edges: [e42, e43, e44, e45],
      effect: data-flow,
      narration: "The client resumes from its delivery cursor and downloads missed encrypted messages in order."
    ]
  }

  animation regional_failover {
    step 1 [
      activate: [message_store, change_data_capture, replication_pipeline, secondary_message_store],
      edges: [e54, e55, e56],
      narration: "Committed messages are continuously copied to a warm secondary region through a replayable replication pipeline."
    ]

    step 2 [
      activate: [failover_controller, conflict_guard, global_load_balancer],
      edges: [e57, e58],
      narration: "After regional health checks and fencing, the failover controller issues a new writer epoch and shifts traffic."
    ]

    step 3 [
      activate: [conflict_guard, secondary_message_store, replay_coordinator, delivery_router],
      edges: [e59, e60, e61],
      effect: data-flow,
      narration: "The secondary region enters single-writer mode, rebuilds delivery cursors and resumes pending message delivery."
    ]
  }
}

  edge e01 sender_device -> global_dns [
    label: "Resolve messaging endpoint",
    kind: sync,
    route: orthogonal
  ]

  edge e02 recipient_device -> global_dns [
    label: "Resolve messaging endpoint",
    kind: sync,
    route: orthogonal
  ]

  edge e03 web_client -> global_dns [
    label: "Resolve messaging endpoint",
    kind: sync,
    route: orthogonal
  ]

  edge e04 global_dns -> global_load_balancer [
    label: "Route to nearest healthy region",
    kind: sync,
    route: orthogonal
  ]

  edge e05 global_load_balancer -> websocket_gateway [
    label: "Establish persistent TLS connection",
    kind: stream,
    route: orthogonal
  ]

  edge e06 global_load_balancer -> api_gateway [
    label: "Route HTTPS API traffic",
    kind: sync,
    route: orthogonal
  ]

  edge e07 websocket_gateway -> auth_service [
    label: "Validate access token",

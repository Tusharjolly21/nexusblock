  edge e01 customer -> merchant_checkout [
    label: "Enter payment method and approve purchase",
    kind: sync,
    route: orthogonal
  ]

  edge e02 merchant_checkout -> merchant_backend [
    label: "Create order and payment request",
    kind: sync,
    route: orthogonal
  ]

  edge e03 merchant_backend -> global_dns [
    label: "Create or confirm payment intent",
    kind: sync,
    route: orthogonal
  ]

  edge e04 merchant_ops -> global_dns [
    label: "Refund, dispute and reporting actions",
    kind: sync,
    route: orthogonal

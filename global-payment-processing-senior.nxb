  animation card_authorization_and_ledger_commit {
    step 1 [
      activate: [customer, merchant_checkout, merchant_backend, global_dns, waf_ddos, api_gateway],
      edges: [e01, e02, e03, e05, e06],
      narration: "The customer confirms the purchase, and the merchant creates a payment intent through the protected regional API edge."
    ]

    step 2 [
      activate: [merchant_auth, distributed_rate_limiter, request_normalizer, idempotency_service, idempotency_store],
      edges: [e07, e09, e10, e11, e12],
      narration: "The platform authenticates the merchant, applies quotas, validates the request and checks the idempotency key before any external side effect."
    ]

    step 3 [
      activate: [payment_orchestrator, payment_state_machine, fraud_engine, tokenization_service, token_vault, hsm_cluster],
      edges: [e13, e14, e15, e16, e17, e18, e19],
      narration: "The orchestrator validates the state transition, evaluates risk and resolves the tokenized payment method inside the PCI-controlled boundary."
    ]

    step 4 [
      activate: [routing_engine, provider_status_store, connector_manager, acquirer_connector_a, card_network, issuer_bank],
      edges: [e23, e24, e25, e26, e30, e32, e33, e34, e35, e36],
      effect: stream-packet,
      narration: "The routing engine chooses the best healthy processor, and the authorization travels through the acquirer, card network and issuing bank."
    ]

    step 5 [
      activate: [payment_orchestrator, payment_repository, payment_outbox, idempotency_service],
      edges: [e41, e42, e44],
      narration: "The canonical payment result, provider reference and outbound event are committed before the response is stored for safe merchant retries."
    ]

    step 6 [
      activate: [payment_outbox, payment_event_bus, ledger_command_service, journal_store, ledger_outbox],
      edges: [e43, e45, e46, e47, e48],
      effect: data-flow,
      narration: "The committed payment event produces a balanced double-entry journal transaction and a separately published immutable ledger event."
    ]

    step 7 [
      activate: [payment_event_bus, balance_projector, balance_store, merchant_event_service, webhook_delivery, merchant_backend],
      edges: [e49, e50, e51, e53, e54],
      narration: "Balance projections update asynchronously while the merchant receives a signed webhook describing the final payment state."
    ]
  }

  animation ambiguous_timeout_and_safe_recovery {
    step 1 [
      activate: [connector_manager, acquirer_connector_a, ambiguity_resolver],
      edges: [e26, e37],
      narration: "The processor request times out after transmission, so the outcome is unknown rather than safely failed."
    ]

    step 2 [
      activate: [ambiguity_resolver, acquirer_connector_a, provider_status_store],
      edges: [e38, e24],
      effect: data-flow,
      narration: "The ambiguity resolver queries the original processor using the provider reference before attempting any alternate route."
    ]

    step 3 [
      activate: [webhook_ingress, provider_callback_queue, payment_orchestrator, payment_repository],
      edges: [e39, e40, e41],
      narration: "A delayed provider callback is verified, queued and applied idempotently to the existing payment attempt."
    ]

    step 4 [
      activate: [payment_outbox, payment_event_bus, ledger_command_service, journal_store],
      edges: [e43, e45, e46],
      narration: "Only the resolved canonical result is published and posted to the ledger, preventing duplicate authorization or duplicate accounting."
    ]
  }

  animation settlement_and_reconciliation {
    step 1 [
      activate: [settlement_scheduler, balance_store, payout_service, treasury_accounts],
      edges: [e65, e66, e67],
      narration: "At the merchant cutoff, the settlement scheduler reads eligible balances and creates a payout instruction through the treasury account."
    ]

    step 2 [
      activate: [payout_service, ledger_command_service, journal_store],
      edges: [e68, e46],
      narration: "The payout is reflected as balanced financial movements in the immutable journal."
    ]

    step 3 [
      activate: [settlement_file_ingest, reconciliation_engine, journal_store, payment_repository],
      edges: [e69, e70, e71],
      effect: data-flow,
      narration: "Processor and bank settlement files are matched against internal payment attempts and ledger entries."
    ]

    step 4 [
      activate: [reconciliation_engine, reconciliation_store, exception_queue, finance_case_manager, finance_ops],
      edges: [e72, e73, e74, e75],
      narration: "Matched rows close automatically; missing, duplicate or amount-mismatched rows create finance investigation cases."
    ]
  }

  animation regional_failover_with_write_fencing {
    step 1 [
      activate: [payment_repository, journal_store, change_capture, replication_pipeline, secondary_payment_store, secondary_journal_store],
      edges: [e77, e78, e79, e80, e81],
      narration: "Committed payment and journal changes continuously replicate to a warm secondary region through an ordered replayable stream."
    ]

    step 2 [
      activate: [failover_controller, writer_epoch_guard, global_dns],
      edges: [e83, e84],
      narration: "After health, replication and fencing checks, the failover controller issues a new writer epoch and shifts traffic."
    ]

    step 3 [
      activate: [writer_epoch_guard, secondary_journal_store, secondary_payment_store, recovery_replayer],
      edges: [e85, e86, e87],
      narration: "The secondary region becomes the single permitted financial writer and reconstructs pending outbox work from replicated state."
    ]

    step 4 [
      activate: [recovery_replayer, provider_reconciliation_guard, acquirer_connector_a, payment_event_bus],
      edges: [e88, e89, e90],
      effect: data-flow,
      narration: "Before replaying ambiguous operations, the platform queries external providers, then resumes only committed unpublished events."
    ]
  }
}

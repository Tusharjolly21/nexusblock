diagram global_payment_processing "Global Payment Processing and Double-Entry Ledger Platform" {
  type: architecture
  direction: LR
  layout: manual

  canvas: {
    width: 7600,
    height: 3000,
    background: "#151515",
    grid: 24
  }

  catalog: {
    category: "Payments",
    difficulty: "Advanced",
    provider: "Cloud Neutral",
    tags: ["payments", "double-entry-ledger", "card-processing", "fraud", "reconciliation", "multi-region"],
    animated: true,
    editable: true
  }

  styles: {
    user:       { fill: "#E8F0FE", stroke: "#4F46E5", text: "#111827" },
    edge:       { fill: "#FFF7ED", stroke: "#EA580C", text: "#111827" },
    security:   { fill: "#FFF1F2", stroke: "#E11D48", text: "#111827" },
    compute:    { fill: "#ECFDF5", stroke: "#059669", text: "#111827" },
    data:       { fill: "#F5F3FF", stroke: "#7C3AED", text: "#111827" },
    stream:     { fill: "#ECFEFF", stroke: "#0891B2", text: "#111827" },
    finance:    { fill: "#FFFBEB", stroke: "#D97706", text: "#111827" },
    external:   { fill: "#FEF2F2", stroke: "#DC2626", text: "#111827" },
    ops:        { fill: "#F3F4F6", stroke: "#4B5563", text: "#111827" }
  }

  group channels "Customers, Merchants and Operations" [
    x: -1850,
    y: -500,
    width: 360,
    height: 980
  ] {
    node customer "Customer" [
      subtitle: "Web, Mobile or In-Store Buyer",
      kind: client,
      icon: lucide:user,
      style: user,
      x: 68,
      y: 48,
      width: 224,
      height: 128
    ]

    node merchant_checkout "Merchant Checkout" [
      subtitle: "Hosted Fields or Payment SDK",

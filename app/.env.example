# Firebase Auth configuration
# Copy this file to `.env` and fill in the values from your Firebase project.
#
# Firebase console → Project settings (gear icon) → General → "Your apps" →
# (Web app) → SDK setup and configuration → Config. Copy these fields:
#   VITE_FIREBASE_API_KEY       = apiKey
#   VITE_FIREBASE_AUTH_DOMAIN   = authDomain   (e.g. your-app.firebaseapp.com)
#   VITE_FIREBASE_PROJECT_ID    = projectId
#   VITE_FIREBASE_APP_ID        = appId
#
# These are safe to expose in the frontend (they identify the project, not secrets).
#
# Enable the sign-in methods used by the buttons:
#   Firebase console → Authentication → Sign-in method → enable:
#     - Google
#     - GitHub          (add the GitHub OAuth app's client id/secret)
#     - Microsoft       (this is the "Continue with Microsoft" button; add an Azure app)
#     - Email/Password
#
# Authorized domains (Authentication → Settings → Authorized domains):
#   localhost is allowed by default; add your production domain there.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# --- AI: natural language → diagram-as-code ---
# Optional. The "✨ Generate" button in the DSL panel calls your own AI server
# (see ../ai-server), which holds the Claude API key. Leave unset for local dev
# (defaults to http://localhost:8787); set to your deployed server in production.
VITE_AI_URL=

# --- Real-time collaboration (self-hosted Yjs, no third-party keys/badges) ---
# Live multiplayer ("?live=1" sessions) sync through your own y-websocket server.
# Start it locally with:  npm run collab   (listens on ws://localhost:1234)
# Leave this unset for local dev; set it to your deployed server in production,
# e.g. wss://collab.yourdomain.com
VITE_COLLAB_WS_URL=

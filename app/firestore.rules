rules_version = '2';

// nexusblock Firestore security rules.
//
// Paste into: Firebase console → Firestore Database → Rules → Publish.
// (Or deploy with `firebase deploy --only firestore:rules` if you use the CLI.)
//
// Model:
//   workspaces/{uid}                     a user's workspace index (their files/folders)
//   workspaces/{uid}/content/{fileId}    per-file doc + canvas snapshot
//   shares/{fileId}                      owner-controlled sharing settings
//
// Sharing: a file's owner writes shares/{fileId}. Another signed-in user may
// READ the owner's content when the share grants "anyone with link" access or
// their email is invited; they may WRITE only when granted an "edit" role.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function myEmail() {
      return request.auth.token.email;
    }

    function publicShareExists(fileId) {
      return exists(/databases/$(database)/documents/publicShares/$(fileId));
    }

    function publicShare(fileId) {
      return get(/databases/$(database)/documents/publicShares/$(fileId)).data;
    }

    function grantExists(fileId) {
      return myEmail() != null &&
        exists(/databases/$(database)/documents/shareGrants/$(fileId)/recipients/$(myEmail()));
    }

    function grant(fileId) {
      return get(/databases/$(database)/documents/shareGrants/$(fileId)/recipients/$(myEmail())).data;
    }

    function ownsContent(fileId) {
      return exists(/databases/$(database)/documents/workspaces/$(request.auth.uid)/content/$(fileId));
    }

    function canReadShared(uid, fileId) {
      return (
        publicShareExists(fileId) &&
        publicShare(fileId).ownerUid == uid &&
        publicShare(fileId).access == 'link'
      ) || (
        grantExists(fileId) &&
        grant(fileId).ownerUid == uid &&
        (grant(fileId).role == 'view' || grant(fileId).role == 'edit')
      );
    }

    function canEditShared(uid, fileId) {
      return (
        publicShareExists(fileId) &&
        publicShare(fileId).ownerUid == uid &&
        publicShare(fileId).access == 'link' &&
        publicShare(fileId).linkRole == 'edit'
      ) || (
        grantExists(fileId) &&
        grant(fileId).ownerUid == uid &&
        grant(fileId).role == 'edit'
      );
    }

    // A user's own workspace index — private to them.
    match /workspaces/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;

      // Per-file content: owner always; shared users per the share doc.
      match /content/{fileId} {
        allow read:  if signedIn() && (request.auth.uid == uid || canReadShared(uid, fileId));
        allow write: if signedIn() && (request.auth.uid == uid || canEditShared(uid, fileId));
      }
    }

    // Private share settings: owner-only. Contains invite email list for the
    // owner's share dialog and must not be readable by arbitrary signed-in users.
    match /shares/{fileId} {
      allow read: if signedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid && ownsContent(fileId);
      allow update: if signedIn() &&
        resource.data.ownerUid == request.auth.uid &&
        request.resource.data.ownerUid == resource.data.ownerUid;
      allow delete: if signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    // Public link metadata: enough to resolve "anyone with link", without
    // exposing invite recipients.
    match /publicShares/{fileId} {
      allow read: if signedIn() && (
        resource.data.ownerUid == request.auth.uid ||
        resource.data.access == 'link'
      );
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid && ownsContent(fileId);
      allow update: if signedIn() &&
        resource.data.ownerUid == request.auth.uid &&
        request.resource.data.ownerUid == resource.data.ownerUid;
      allow delete: if signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    // Per-recipient invite grants. A user can read only their own grant; the
    // owner can create/update/delete grants for their file.
    match /shareGrants/{fileId}/recipients/{email} {
      allow read: if signedIn() && (
        resource.data.ownerUid == request.auth.uid ||
        email == myEmail()
      );
      allow create: if signedIn() &&
        request.resource.data.ownerUid == request.auth.uid &&
        ownsContent(fileId) &&
        request.resource.data.email == email;
      allow update: if signedIn() &&
        resource.data.ownerUid == request.auth.uid &&
        request.resource.data.ownerUid == resource.data.ownerUid &&
        request.resource.data.email == resource.data.email;
      allow delete: if signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    // Invite email queue. A Cloud Function / Firebase email extension can watch
    // these docs and send transactional invites.
    match /shareInvites/{inviteId} {
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow read: if signedIn() && (
        resource.data.ownerUid == request.auth.uid ||
        resource.data.recipientEmail == myEmail()
      );
      allow update, delete: if false;
    }
  }
}

rules_version = '2';

// nexusblock Firestore security rules.
//
// Paste into: Firebase console → Firestore Database → Rules → Publish.
// (Or deploy with `firebase deploy --only firestore:rules` if you use the CLI.)
//
// Model:
//   workspaces/{uid}                     a user's workspace index (their files/folders)
//   workspaces/{uid}/content/{fileId}    per-file doc + canvas snapshot
//   shares/{fileId}                      owner-controlled sharing settings
//
// Sharing: a file's owner writes shares/{fileId}. Another signed-in user may
// READ the owner's content when the share grants "anyone with link" access or
// their email is invited; they may WRITE only when granted an "edit" role.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function myEmail() {
      return request.auth.token.email;
    }

    function shareExists(fileId) {
      return exists(/databases/$(database)/documents/shares/$(fileId));
    }

    function share(fileId) {
      return get(/databases/$(database)/documents/shares/$(fileId)).data;
    }

    // Email is on an invite (with either role) → may view.
    function invitedToView(s) {
      return myEmail() != null && s.invites.hasAny([
        { 'email': myEmail(), 'role': 'view' },
        { 'email': myEmail(), 'role': 'edit' }
      ]);
    }

    // Email is on an invite with the 'edit' role → may edit.
    function invitedToEdit(s) {
      return myEmail() != null && s.invites.hasAny([
        { 'email': myEmail(), 'role': 'edit' }
      ]);
    }

    function canReadShared(fileId) {
      return shareExists(fileId) &&
        (share(fileId).access == 'link' || invitedToView(share(fileId)));
    }

    function canEditShared(fileId) {
      return shareExists(fileId) && (
        (share(fileId).access == 'link' && share(fileId).linkRole == 'edit')
        || invitedToEdit(share(fileId))
      );
    }

    // A user's own workspace index — private to them.
    match /workspaces/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;

      // Per-file content: owner always; shared users per the share doc.
      match /content/{fileId} {
        allow read:  if signedIn() && (request.auth.uid == uid || canReadShared(fileId));
        allow write: if signedIn() && (request.auth.uid == uid || canEditShared(fileId));
      }
    }

    // Share settings: readable by any signed-in user (to resolve a link);
    // writable only by the file's owner.
    match /shares/{fileId} {
      allow read:  if signedIn();
      allow write: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
    }

    // Invite email queue. A Cloud Function / Firebase email extension can watch
    // these docs and send transactional invites.
    match /shareInvites/{inviteId} {
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow read: if signedIn() && (
        resource.data.ownerUid == request.auth.uid ||
        resource.data.recipientEmail == myEmail()
      );
      allow update, delete: if false;
    }
  }
}
